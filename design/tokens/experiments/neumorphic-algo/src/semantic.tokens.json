      "bg-hover":   { "$value": "color-mix(in oklch, oklch(0.91 0.012 145) 86%, oklch(0.22 0.008 262))", "$extensions": { "com.opntrntbl.dark": "color-mix(in oklch, oklch(0.28 0.015 145) 86%, oklch(0.90 0.006 262))" } },
      "bg-pressed": { "$value": "color-mix(in oklch, oklch(0.91 0.012 145) 74%, oklch(0.22 0.008 262))", "$extensions": { "com.opntrntbl.dark": "color-mix(in oklch, oklch(0.28 0.015 145) 74%, oklch(0.90 0.006 262))" } },
