{
  "shadow-light": {
    "$value": "oklch(calc(var(--base-surface-l) + var(--base-shadow-l-delta)) var(--base-shadow-c) var(--base-hue))",
    "$description": "Lightness = surface-l + shadow-l-delta. Live in DevTools."
  },
  "shadow-dark": {
    "$value": "oklch(calc(var(--base-surface-l) - var(--base-shadow-d-delta)) var(--base-shadow-c) var(--base-hue))"
  },
  "surface": {
    "canvas": {
      "background": { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" }
    },
    "base": {
      "background": { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" },
      "hover":      { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" },
      "pressed":    { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" }
    },
    "raised": {
      "background": { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" },
      "elevation":  { "$value": "calc(var(--base-shadow-offset) * -1px) calc(var(--base-shadow-offset) * -1px) calc(var(--base-shadow-blur) * 1px) oklch(calc(var(--base-surface-l) + var(--base-shadow-l-delta)) var(--base-shadow-c) var(--base-hue)), calc(var(--base-shadow-offset) * 1px) calc(var(--base-shadow-offset) * 1px) calc(var(--base-shadow-blur) * 1px) oklch(calc(var(--base-surface-l) - var(--base-shadow-d-delta)) var(--base-shadow-c) var(--base-hue))" }
    },
    "sunken": {
      "background": { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" },
      "hover":      { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" },
      "pressed":    { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" }
    },
    "overlay": {
      "background": { "$value": "oklch(var(--base-surface-l) var(--base-surface-c) var(--base-hue))" },
      "elevation":  { "$value": "calc(var(--base-shadow-offset) * -2px) calc(var(--base-shadow-offset) * -2px) calc(var(--base-shadow-blur) * 2.5px) oklch(calc(var(--base-surface-l) + var(--base-shadow-l-delta)) var(--base-shadow-c) var(--base-hue)), calc(var(--base-shadow-offset) * 2px) calc(var(--base-shadow-offset) * 2px) calc(var(--base-shadow-blur) * 2.5px) oklch(calc(var(--base-surface-l) - var(--base-shadow-d-delta)) var(--base-shadow-c) var(--base-hue))" }
    },
    "dim":    { "$value": "oklch(0.30 0.008 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.15 0.008 262)" } },
    "bright": { "$value": "oklch(0.97 0.004 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.40 0.008 262)" } }
  },
  "elevation": {
    "flat":         { "$value": "0px 0px 0px 0px transparent" },
    "raised":       { "$value": "calc(var(--base-shadow-offset) * -1px) calc(var(--base-shadow-offset) * -1px) calc(var(--base-shadow-blur) * 1px) oklch(calc(var(--base-surface-l) + var(--base-shadow-l-delta)) var(--base-shadow-c) var(--base-hue)), calc(var(--base-shadow-offset) * 1px) calc(var(--base-shadow-offset) * 1px) calc(var(--base-shadow-blur) * 1px) oklch(calc(var(--base-surface-l) - var(--base-shadow-d-delta)) var(--base-shadow-c) var(--base-hue))" },
    "raised-hover": { "$value": "calc(var(--base-shadow-offset) * -1px) calc(var(--base-shadow-offset) * -1px) calc(var(--base-shadow-blur) * 1px) oklch(calc(var(--base-surface-l) + var(--base-shadow-l-delta)) var(--base-shadow-c) var(--base-hue)), calc(var(--base-shadow-offset) * 1px) calc(var(--base-shadow-offset) * 1px) calc(var(--base-shadow-blur) * 1px) oklch(calc(var(--base-surface-l) - var(--base-shadow-d-delta)) var(--base-shadow-c) var(--base-hue))" },
    "pressed":      { "$value": "inset calc(var(--base-shadow-offset) * -0.75px) calc(var(--base-shadow-offset) * -0.75px) calc(var(--base-shadow-blur) * 0.5px) oklch(calc(var(--base-surface-l) + var(--base-shadow-l-delta)) var(--base-shadow-c) var(--base-hue)), inset calc(var(--base-shadow-offset) * 0.75px) calc(var(--base-shadow-offset) * 0.75px) calc(var(--base-shadow-blur) * 0.5px) oklch(calc(var(--base-surface-l) - var(--base-shadow-d-delta)) var(--base-shadow-c) var(--base-hue))" },
    "sunken":       { "$value": "inset calc(var(--base-shadow-offset) * -1px) calc(var(--base-shadow-offset) * -1px) calc(var(--base-shadow-blur) * 1px) oklch(calc(var(--base-surface-l) + var(--base-shadow-l-delta)) var(--base-shadow-c) var(--base-hue)), inset calc(var(--base-shadow-offset) * 1px) calc(var(--base-shadow-offset) * 1px) calc(var(--base-shadow-blur) * 1px) oklch(calc(var(--base-surface-l) - var(--base-shadow-d-delta)) var(--base-shadow-c) var(--base-hue))" },
    "overlay":      { "$value": "calc(var(--base-shadow-offset) * -2px) calc(var(--base-shadow-offset) * -2px) calc(var(--base-shadow-blur) * 2.5px) oklch(calc(var(--base-surface-l) + var(--base-shadow-l-delta)) var(--base-shadow-c) var(--base-hue)), calc(var(--base-shadow-offset) * 2px) calc(var(--base-shadow-offset) * 2px) calc(var(--base-shadow-blur) * 2.5px) oklch(calc(var(--base-surface-l) - var(--base-shadow-d-delta)) var(--base-shadow-c) var(--base-hue))" }
  },
  "border": {
    "subtle":  { "$value": "oklch(0.88 0.006 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.32 0.008 262)" } },
    "default": { "$value": "oklch(0.84 0.008 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.36 0.009 262)" } },
    "strong":  { "$value": "oklch(0.78 0.010 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.42 0.010 262)" } },
