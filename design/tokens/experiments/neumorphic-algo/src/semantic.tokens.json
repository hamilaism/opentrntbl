  "accent": {
    "default": { "$value": "oklch(0.55 0.14 85)",                                "$extensions": { "com.opntrntbl.dark": "oklch(0.65 0.14 85)" } },
    "hover":   { "$value": "color-mix(in oklch, oklch(0.55 0.14 85) 88%, #fff)", "$extensions": { "com.opntrntbl.dark": "color-mix(in oklch, oklch(0.65 0.14 85) 88%, #fff)" } },
    "pressed": { "$value": "color-mix(in oklch, oklch(0.55 0.14 85) 80%, #000)", "$extensions": { "com.opntrntbl.dark": "color-mix(in oklch, oklch(0.65 0.14 85) 80%, #000)" } }
  },
  "text": {
    "color": {
      "primary":     { "$value": "oklch(0.22 0.008 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.90 0.006 262)" } },
      "secondary":   { "$value": "oklch(0.44 0.008 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.72 0.006 262)" } },
      "placeholder": { "$value": "oklch(0.55 0.006 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.60 0.006 262)" } },
      "disabled":    { "$value": "oklch(0.62 0.006 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.50 0.006 262)" } },
      "inverse":     { "$value": "oklch(0.96 0.003 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.18 0.006 262)" } },
      "accent":      { "$value": "oklch(0.40 0.14 85)",   "$extensions": { "com.opntrntbl.dark": "oklch(0.75 0.14 85)" } },
      "on-accent":   { "$value": "oklch(0.10 0.008 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.10 0.008 262)" } },
      "on-dim":      { "$value": "oklch(0.94 0.004 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.92 0.004 262)" } },
      "on-bright":   { "$value": "oklch(0.18 0.008 262)", "$extensions": { "com.opntrntbl.dark": "oklch(0.18 0.008 262)" } }
    },
    "caption":       { "family": { "$value": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }, "size": { "$value": "0.75rem" }, "weight": { "$value": 400 }, "line-height": { "$value": 1.2 } },
    "small":         { "family": { "$value": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }, "size": { "$value": "0.875rem" }, "weight": { "$value": 400 }, "line-height": { "$value": 1.4 } },
    "body":          { "family": { "$value": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }, "size": { "$value": "1rem" }, "weight": { "$value": 400 }, "line-height": { "$value": 1.4 } },
    "body-emphasis": { "family": { "$value": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }, "size": { "$value": "1rem" }, "weight": { "$value": 600 }, "line-height": { "$value": 1.4 } },
    "subheading":    { "family": { "$value": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }, "size": { "$value": "1.25rem" }, "weight": { "$value": 600 }, "line-height": { "$value": 1.2 } },
    "heading-3":     { "family": { "$value": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }, "size": { "$value": "1.5rem" }, "weight": { "$value": 700 }, "line-height": { "$value": 1.2 } },
    "heading-2":     { "family": { "$value": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }, "size": { "$value": "2rem" }, "weight": { "$value": 700 }, "line-height": { "$value": 1.0 } },
    "heading-1":     { "family": { "$value": "Inter, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif" }, "size": { "$value": "2.5rem" }, "weight": { "$value": 800 }, "line-height": { "$value": 1.0 } }
  },
