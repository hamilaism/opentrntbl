      "bg-pressed": { "$value": "color-mix(in oklch, oklch(0.91 0.012 55) 74%, oklch(0.22 0.008 262))", "$extensions": { "com.opntrntbl.dark": "color-mix(in oklch, oklch(0.28 0.015 55) 74%, oklch(0.90 0.006 262))" } },
