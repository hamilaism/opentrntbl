{
  "name": "opentrntbl-design",
  "version": "1.2.0",
  "private": true,
  "type": "module",
  "description": "openTRNTBL design system — token gallery and components (Mac-side tooling, does not ship to the CHIP firmware).",
  "scripts": {
    "tokens:build": "python3 design/tokens/scripts/bundle.py && python3 design/tokens/scripts/generate-css.py",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build -o storybook-static",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/html-vite": "^10.3.5",
    "@vitest/browser": "^4.1.5",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "playwright": "^1.59.1",
    "storybook": "^10.3.5",
    "storybook-addon-pseudo-states": "^10.3.5",
    "vite": "^5.4.11",
    "vitest": "^4.1.5"
  }
}
